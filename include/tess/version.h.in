#pragma once

// clang-format off
/** Compile-time major component of the configured tess version. */
#define TESS_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
/** Compile-time minor component of the configured tess version. */
#define TESS_VERSION_MINOR @PROJECT_VERSION_MINOR@
/** Compile-time patch component of the configured tess version. */
#define TESS_VERSION_PATCH @PROJECT_VERSION_PATCH@
// clang-format on

namespace tess {

/** Semantic version components exposed without string parsing. */
struct version {
  int major;
  int minor;
  int patch;
};

/** Version of the tess headers generated by the active CMake package. */
inline constexpr version library_version{
    TESS_VERSION_MAJOR,
    TESS_VERSION_MINOR,
    TESS_VERSION_PATCH,
};

}  // namespace tess
