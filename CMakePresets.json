{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Developer Debug",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TESS_BUILD_TESTING": "ON",
        "TESS_ENABLE_WARNINGS": "ON"
      }
    },
    {
      "name": "dev-werror",
      "displayName": "Developer Debug Warnings As Errors",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TESS_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "dev-asan",
      "displayName": "Developer Debug ASan UBSan",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TESS_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "dev-clang-tidy",
      "displayName": "Developer Debug clang-tidy Gate",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TESS_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "dev-clang-tidy-advisory",
      "displayName": "Developer Debug clang-tidy Advisory",
      "inherits": "dev-clang-tidy",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TESS_CLANG_TIDY_CONFIG": "${sourceDir}/.clang-tidy-advisory"
      }
    },
    {
      "name": "dev-cppcheck",
      "displayName": "Developer Debug cppcheck",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TESS_ENABLE_CPPCHECK": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TESS_BUILD_TESTING": "ON",
        "TESS_ENABLE_WARNINGS": "ON"
      }
    },
    {
      "name": "bench",
      "displayName": "Benchmark Release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TESS_BUILD_TESTING": "ON",
        "TESS_BUILD_BENCHMARKS": "ON",
        "TESS_ENABLE_WARNINGS": "ON"
      }
    },
    {
      "name": "bench-profile",
      "displayName": "Benchmark Profiling",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS_RELWITHDEBINFO":
            "-O3 -g -fno-omit-frame-pointer -DNDEBUG",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TESS_BUILD_TESTING": "ON",
        "TESS_BUILD_BENCHMARKS": "ON",
        "TESS_ENABLE_WARNINGS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "dev-werror",
      "configurePreset": "dev-werror"
    },
    {
      "name": "dev-asan",
      "configurePreset": "dev-asan"
    },
    {
      "name": "dev-clang-tidy",
      "configurePreset": "dev-clang-tidy"
    },
    {
      "name": "dev-clang-tidy-advisory",
      "configurePreset": "dev-clang-tidy-advisory"
    },
    {
      "name": "dev-cppcheck",
      "configurePreset": "dev-cppcheck"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "bench",
      "configurePreset": "bench"
    },
    {
      "name": "bench-profile",
      "configurePreset": "bench-profile"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-werror",
      "configurePreset": "dev-werror",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-asan",
      "configurePreset": "dev-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-clang-tidy",
      "configurePreset": "dev-clang-tidy",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-clang-tidy-advisory",
      "configurePreset": "dev-clang-tidy-advisory",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-cppcheck",
      "configurePreset": "dev-cppcheck",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "bench",
      "configurePreset": "bench",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "bench-profile",
      "configurePreset": "bench-profile",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
